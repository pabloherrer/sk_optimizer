# Virtual environments — never commit these
sk_venv/
venv/
env/
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Temp Excel lock files
~$*.xlsx

# OS junk
.DS_Store
Thumbs.db
.Rhistory

# Secrets / local overrides (if added later)
.env

# Per-machine settings — each machine has its own, never push
local_config.json

# ── Pre-cleanup archive of v1/v2 code (gitignored; safe to rm -rf later) ──
_obsolete_v1v2_pre_cleanup/

# ── Per-machine runtime state (regenerated by every run, do not push) ──
data/inventory_state*.json
data/inventory_state*.json.*
data/plan.json
data/plan.json.*
data/runs.jsonl
data/truck_unavailable.json
data/user_overrides.json
data/route_geom_cache.json
data/*.bak
data/*.before_fix
data/*.pre_cold
data/*.tmp.npz

# ── Generated outputs (regenerated each run) ──
output/
final/output/
final/stress/EXECUTION_LOG*.md
final/stress/execution_log*.json
final/backtest_stockout_raw.json
final/backtest_v8h.log
final/app/last_run.json
