# Virtual environments — never commit these
sk_venv/
venv/
env/
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Generated outputs — too large / regenerated each run
output/

# Temp Excel lock files
~$*.xlsx

# Runtime state
data/inventory_state.json

# OS junk
.DS_Store
Thumbs.db

# Secrets / local overrides (if added later)
.env

# Per-machine settings (set once, never overwritten by updates)
local_config.json
